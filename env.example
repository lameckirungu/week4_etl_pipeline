# ─────────────────────────────────────────────────────────────────────────────
# .env.example — KPC Ops ETL Pipeline Configuration Template
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in any values you want to override (defaults shown below are safe)
#   3. Never commit .env to Git — it is in .gitignore
#   4. This .env.example IS committed — it documents config without secrets
# ─────────────────────────────────────────────────────────────────────────────

# ── File paths ────────────────────────────────────────────────────────────────
# Path to the raw sensor log CSV (relative to run_pipeline.py)
RAW_CSV_PATH=data/ops_sensor_log_dirty.csv

# Path to the output SQLite database
OUTPUT_DB_PATH=data/ops_pipeline.db

# Name of the target table inside the database
OUTPUT_TABLE=cleaned_sensor_log

# Path to the pipeline log file
LOG_FILE=pipeline.log

# ── Sensor thresholds ────────────────────────────────────────────────────────
# These define the physical operating envelope of the plant.
# Readings outside these ranges are treated as sensor faults and nulled out.
# Adjust these if the plant operating parameters change.

MAX_PRESSURE_BAR=15
MIN_PRESSURE_BAR=0

MAX_TEMP_C=100
MIN_TEMP_C=50

MAX_FLOW_M3H=500
MIN_FLOW_M3H=100
